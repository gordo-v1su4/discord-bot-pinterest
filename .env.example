# Discord (required for interactions)
# Get from https://discord.com/developers/applications/<APPLICATION_ID>/information
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
# Bot token (optional; needed for follow-up or registering commands via REST)
DISCORD_TOKEN=

# Server
PORT=8080

# Pinterest (optional; for /pinterest link and future API)
PINTEREST_APP_ID=
PINTEREST_OAUTH_URL=https://www.pinterest.com/oauth/
