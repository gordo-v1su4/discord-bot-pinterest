# Pindeck Discord Bot – same vars as pindeck/services/discord-bot
# Load order: .env.local, .env (cwd), then ../../.env.local, ../.env.local, etc.

# Discord (required)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# or DISCORD_APPLICATION_ID (same value)
DISCORD_GUILD_ID=

# Image presets (optional – uses samples if missing)
# DISCORD_IMAGES_JSON=[{"id":"x","label":"X","url":"https://...","emoji":"🎉"}]

# Ingest to Pindeck
INGEST_API_KEY=
DISCORD_INGEST_EMOJIS=📌
PINDECK_USER_ID=

# Convex (ingest/queue/moderation derive from these if not set)
# CONVEX_SITE_URL or VITE_CONVEX_SITE_URL
# PINDECK_INGEST_URL, PINDECK_DISCORD_QUEUE_URL, PINDECK_DISCORD_MODERATION_URL
